# Firewebz Video Studio — local environment
# Copy this file to .env.local and fill in keys as needed.

APP_MODE=local

# SQLite (local file). Prisma reads this.
DATABASE_URL="file:./dev.db"

# --- LLM provider (concepts, captions, hashtags, CTAs) ---
# Options: gemini | mock
LLM_PROVIDER=mock
GEMINI_API_KEY=

# --- Video provider ---
# Options: gemini_veo | runway | mock | ffmpeg_template
VIDEO_PROVIDER=mock

# Runway fallback (only needed if VIDEO_PROVIDER=runway)
RUNWAY_API_KEY=

# Local file storage paths (relative to project root)
UPLOAD_DIR=./storage/uploads
GENERATED_VIDEO_DIR=./storage/generated-videos
